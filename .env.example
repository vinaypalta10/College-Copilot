# Copy this file to `.env` and fill in your provider key. `tsx` auto-loads
# `.env` on `npm run dev` / `npm start`. The .env file is gitignored.

# ─── Claude API (Anthropic) ───
# Powers the course-advisor's natural-language parsing + the outreach writer/critic.
# Without a key, the advisor falls back to a keyword heuristic and scoring stays
# deterministic — everything still works, just less smart.
# Key format: sk-ant-api03-…   Get one at https://console.anthropic.com/settings/keys
# Read by: src/providers/anthropic.ts
ANTHROPIC_API_KEY=
ANTHROPIC_WRITER_MODEL=claude-opus-4-8
ANTHROPIC_SCORER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_CRITIC_MODEL=claude-haiku-4-5-20251001

# ─── Industry jobs search (optional) ───
# The Jobs/Internships tab is query-driven across industries. The keyless
# providers (Remotive, The Muse, public ATS boards) work out of the box. Adding
# a free Adzuna key broadens coverage to all industries + locations (e.g.
# "investment banking on the east coast"). Get free keys at
# https://developer.adzuna.com/  Read by: src/agents/industry-jobs/job-search-agent.ts
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Adzuna country code for the search market (us, gb, ca, …). Default: us
# ADZUNA_COUNTRY=us

# Deepgram speech-to-text
# Powers the optional mic buttons next to text prompts. Audio is recorded in the
# browser, sent to this server, then transcribed by Deepgram with Nova-3.
# Without a key, voice input is hidden and text input continues to work.
# Read by: src/providers/deepgram.ts + src/api/voice.ts
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_TIMEOUT_MS=20000

# ─── Writer quality loop ───
# The critic skill rescores drafts; writer retries once if score < threshold.
WRITER_QUALITY_THRESHOLD=4
WRITER_MAX_ITERATIONS=2

# ─── Auth (College Copilot) ───
# Google Sign-In. Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must equal OAUTH_REDIRECT_URL below.
# When these are blank, local development falls back to "dev-login" (email only,
# no password). Production never enables it implicitly. Read by: src/auth/google.ts
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:4174/api/auth/google/callback
# Optional: restrict sign-in to one email domain, e.g. berkeley.edu
# OAUTH_HOSTED_DOMAIN=berkeley.edu
# Explicitly opt in to dev-login, including in production (unsafe for public deployments).
# DEV_LOGIN=true

# ─── Course data ───
# Default term used by `npm run import:courses` and the UI.
# (Named COURSE_TERM, not TERM, to avoid clashing with the shell's $TERM.)
COURSE_TERM=fall-2026
# Berkeleytime is the primary catalog source (no key needed).
# BERKELEYTIME_BASE_URL=https://berkeleytime.com
# Optional official UC Berkeley SIS API (needs CalNet-issued credentials).
# SIS_APP_ID=
# SIS_APP_KEY=

# ─── Redis (optional cache — sponsor track) ───
# When set, the assembled Berkeley course catalog is cached in Redis so the
# advisor/Discover hot path doesn't rebuild its candidate set from SQLite on
# every request. Unset (or unreachable) → the app transparently falls back to
# SQLite. Read by: src/db/redis.ts + src/db/courseCache.ts
# Local:  redis://localhost:6379
# Cloud:  redis://default:<password>@<host>:<port>   (e.g. Redis Cloud free tier)
# REDIS_URL=redis://localhost:6379
# How long (seconds) a cached catalog snapshot lives before a rebuild. Default 1800.
# REDIS_CATALOG_TTL=1800
# Semantic search vector index lives in Redis too (cc:vecidx:<term>); its TTL (seconds).
# REDIS_VECTOR_TTL=1800

# ─── Server ───
PORT=4174
SCAN_INTERVAL_MS=21600000
SCAN_CONCURRENCY=4
SCAN_TIMEOUT_MS=15000
RMP_TIMEOUT_MS=4000
LOG_LEVEL=info
